{
  "info": {
    "_postman_id": "c3a1b5d4-e8f2-43a7-8902-1a2b3c4d5e6f",
    "name": "Mini ERP + CRM Operations Portal API",
    "description": "Comprehensive Postman collection for the Mini ERP & CRM Operations Portal API. Covers Authentication (RBAC), Customers CRM, Products & Inventory (with Stock Movement transactions), and Sales Challans (with stock-safe confirmation logic).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Login - Admin User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.token) {",
                  "    pm.collectionVariables.set('token', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Authenticates user and returns a JWT token along with user details. Automatically saves token to collection variable."
          }
        },
